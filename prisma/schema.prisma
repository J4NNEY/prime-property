generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin") // admin | superadmin
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  auditLogs  AuditLog[]

  @@index([email])
}

model Property {
  id           String   @id @default(cuid())
  namaProperty String
  group        String?
  lebar        Float
  panjang      Float
  hadap        String   // comma-separated: Utara,Selatan,Timur,Barat
  tipe         String   // Ruko | Villa
  tingkat      Float
  price        BigInt
  carport      Boolean  @default(false)
  status       String   @default("in_stock") // in_stock | sold_out
  siap         String   // siap_huni | siap_kosong | siap_huni_renovasi
  mapsLink     String?
  kawasan      String   // comma-separated tags
  unit         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  createdBy    String
  creator      User     @relation(fields: [createdBy], references: [id])

  @@index([deletedAt])
  @@index([status])
  @@index([tipe])
  @@index([kawasan])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // create | update | delete | restore
  entityType String   // property | user
  entityId   String   // polymorphic: id Property atau User (tanpa FK)
  changes    String?  // JSON string of changes
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  nama      String
  email     String
  nomorHp   String
  pesan     String
  createdAt DateTime @default(now())
  ipAddress String?
}
